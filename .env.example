# ================================
# TOLQAR Platform — Environment Variables
# انسخ هذا الملف باسم .env وعبّي القيم الحقيقية
# ================================

# قاعدة البيانات (PostgreSQL) — احصل عليها من Vercel Postgres, Neon, أو Supabase
DATABASE_URL="postgresql://user:password@host:5432/tolqar?schema=public"

# NextAuth — أنشئ مفتاح عشوائي بأمر: openssl rand -base64 32
NEXTAUTH_SECRET="ضع-مفتاح-عشوائي-هنا"
NEXTAUTH_URL="https://tolqar.com"

# Stripe (الدفع العالمي) — من dashboard.stripe.com
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PayPal
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# محافظ العملات الرقمية (تُدخل يدويًا كنص، لا تحتاج API خارجي بالضرورة)
USDT_TRC20_ADDRESS=""
USDT_BEP20_ADDRESS=""
BINANCE_PAY_ID=""
